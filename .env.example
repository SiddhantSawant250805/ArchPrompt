# ArchPrompt Environment Variables

# ── Required for Diagram Generation ─────────────────────────────────────────
# Get your Gemini API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Optional: Alternative LLM Provider Fallback ─────────────────────────────
# GROQ_API_KEY=your-groq-api-key-here

# ── Optional: GitHub Export ──────────────────────────────────────────────────
# GITHUB_TOKEN=your-github-pat-with-repo-permissions

# ── Supabase (Pre-configured) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
